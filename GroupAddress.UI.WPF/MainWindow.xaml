<Window x:Class="GroupAddress.UI.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GroupAddress.UI.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="570" Width="1012"
        d:DataContext="{d:DesignInstance local:MainWindow, IsDesignTimeCreatable=True}">

    <DockPanel>
        <local:MenuControl DockPanel.Dock="Top" Test="{Binding TestMain}" />
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="23*" />
                <RowDefinition Height="254*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="79*"/>
                <ColumnDefinition Width="427*"/>
            </Grid.ColumnDefinitions>
            <DataGrid d:ItemsSource="{d:SampleData ItemCount=5}" Margin="65,78,66,93" Grid.Column="1" Grid.Row="1"/>
            <Button Content="Button" HorizontalAlignment="Left" Margin="84,40,0,0" Grid.Row="1" VerticalAlignment="Top" Click="Button_Click"/>

        </Grid>

    </DockPanel>
</Window>
