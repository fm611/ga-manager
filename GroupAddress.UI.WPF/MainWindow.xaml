<Window x:Class="GroupAddress.UI.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GroupAddress.UI.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="570" Width="1012">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei" >
                <MenuItem Header="Neu" InputGestureText="Strg+N"/>
                <MenuItem Header="Öffnen" />
                <MenuItem Header="Speichern" />
            </MenuItem>
        </Menu>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="23*" />
                <RowDefinition Height="254*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="79*"/>
                <ColumnDefinition Width="427*"/>
            </Grid.ColumnDefinitions>
            <DataGrid d:ItemsSource="{d:SampleData ItemCount=5}" Margin="65,78,66,93" Grid.Column="1" Grid.Row="1"/>

        </Grid>

    </DockPanel>
</Window>
