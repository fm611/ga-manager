<UserControl x:Class="GroupAddress.UI.WPF.MenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GroupAddress.UI.WPF"
             xmlns:vm="clr-namespace:GroupAddress.UI.WPF.ViewModel"
             mc:Ignorable="d"              
            d:DataContext="{d:DesignInstance vm:MenuViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Menu DockPanel.Dock="Top">
        <MenuItem Header="Datei" >
            <MenuItem Header="Neu" InputGestureText="Strg+N"/>
            <MenuItem Header="Öffnen" >
                <MenuItem Header="Datei" />
                <Separator />
                <MenuItem Header="Beispiel" />
            </MenuItem>
            <MenuItem Header="Speichern" />
            <Separator />
            <MenuItem Header="Export" />
            <MenuItem Header="Import" />
        </MenuItem>
        <MenuItem Header="{Binding Test}" />
    </Menu>
</UserControl>
