<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GAManager.Desktop"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        x:Class="GAManager.Desktop.MainWindow"
        mc:Ignorable="d"
        Title="Gruppenadressen Manager"
        Icon="Assets/app.ico"
        Height="928" Width="1471"
        Background="#FF292929"
        Foreground="White"
        FontFamily="Segoe UI, Segoe UI Web (West European), Arial, sans-serif"
        Closing="Window_Closing"
    >

    <DockPanel Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Window}}">
        <wv2:WebView2 x:Name="Browser"/>
    </DockPanel>
</Window>
